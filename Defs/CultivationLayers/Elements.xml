<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Air Element -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Element_Air</defName>
    <label>Air Kinship</label>
    <description>Sudden, evasive, explosive. Grants burst movement and rapid repositioning, but lacks sustain in long fights.</description>
    <layerType>Element</layerType>
    <titleSuffix>Wind</titleSuffix>
    <passiveStatOffsets>
      <li>
        <stat>CleaningSpeed</stat>
        <value>0.25</value>
      </li>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Cooking</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li>
        <stat>MoveSpeed</stat>
        <value>0.60</value>
      </li>
      <li>
        <stat>MeleeDodgeChance</stat>
        <value>0.15</value>
      </li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Fire Element -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Element_Fire</defName>
    <label>Fire Kinship</label>
    <description>Escalation, heat, momentum. Low initial impact, but builds rapidly into high-damage attack momentum.</description>
    <layerType>Element</layerType>
    <titleSuffix>Blaze</titleSuffix>
    <passiveStatOffsets>
      <li>
        <stat>CookSpeed</stat>
        <value>0.20</value>
      </li>
      <li>
        <stat>SmeltingSpeed</stat>
        <value>0.20</value>
      </li>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Crafting</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li>
        <stat>MeleeDamageFactor</stat>
        <value>0.20</value>
      </li>
      <li>
        <stat>RangedWeapon_WarmupMultiplier</stat>
        <value>-0.15</value>
      </li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Water Element -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Element_Water</defName>
    <label>Water Kinship</label>
    <description>Sustained force, pressure, inevitability. Slow starting speed, but builds extreme endurance and stability.</description>
    <layerType>Element</layerType>
    <titleSuffix>River</titleSuffix>
    <passiveStatOffsets>
      <li>
        <stat>RestRateMultiplier</stat>
        <value>0.15</value>
      </li>
      <li>
        <stat>MedicalSurgerySuccessChance</stat>
        <value>0.15</value>
      </li>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Medicine</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li>
        <stat>ArmorRating_Sharp</stat>
        <value>0.10</value>
      </li>
      <li>
        <stat>ArmorRating_Blunt</stat>
        <value>0.10</value>
      </li>
      <li>
        <stat>MeleeDodgeChance</stat>
        <value>0.05</value>
      </li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

</Defs>
