<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Air Element -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Element_Air</defName>
    <label>Air Kinship</label>
    <description>Sudden, evasive, explosive. Grants burst movement and rapid repositioning, but lacks sustain in long fights.</description>
    <layerType>Element</layerType>
    <titleSuffix>Wind</titleSuffix>
    <passiveStatOffsets>
      <CleaningSpeed>0.25</CleaningSpeed>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Cooking</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <MoveSpeed>0.60</MoveSpeed>
      <MeleeDodgeChance>0.15</MeleeDodgeChance>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Fire Element -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Element_Fire</defName>
    <label>Fire Kinship</label>
    <description>Escalation, heat, momentum. Low initial impact, but builds rapidly into high-damage attack momentum.</description>
    <layerType>Element</layerType>
    <titleSuffix>Blaze</titleSuffix>
    <passiveStatOffsets>
      <CookSpeed>0.20</CookSpeed>
      <SmeltingSpeed>0.20</SmeltingSpeed>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Crafting</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <MeleeDamageFactor>0.20</MeleeDamageFactor>
      <RangedWeapon_WarmupMultiplier>-0.15</RangedWeapon_WarmupMultiplier>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Water Element -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Element_Water</defName>
    <label>Water Kinship</label>
    <description>Sustained force, pressure, inevitability. Slow starting speed, but builds extreme endurance and stability.</description>
    <layerType>Element</layerType>
    <titleSuffix>River</titleSuffix>
    <passiveStatOffsets>
      <RestRateMultiplier>0.15</RestRateMultiplier>
      <MedicalSurgerySuccessChance>0.15</MedicalSurgerySuccessChance>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Medicine</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <ArmorRating_Sharp>0.10</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
      <MeleeDodgeChance>0.05</MeleeDodgeChance>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

</Defs>
