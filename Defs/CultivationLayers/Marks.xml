<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Ox Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Ox</defName>
    <label>Mark of the Ox</label>
    <description>The wall, the burden-bearer, the breaker. Embraces heavy shields, hammers, mining, and construction.</description>
    <layerType>Mark</layerType>
    <titleSuffix>Wall</titleSuffix>
    <passiveStatOffsets>
      <li Key="MiningSpeed">0.20</li>
      <li Key="ConstructionSpeed">0.20</li>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Mining</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Construction</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li Key="ArmorRating_Sharp">0.25</li>
      <li Key="ArmorRating_Blunt">0.25</li>
      <li Key="MoveSpeed">-0.60</li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Fox Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Fox</defName>
