<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Ox Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Ox</defName>
    <label>Mark of the Ox</label>
    <description>The wall, the burden-bearer, the breaker. Embraces heavy shields, hammers, mining, and construction.</description>
    <layerType>Mark</layerType>
    <titleSuffix>Wall</titleSuffix>
    <passiveStatOffsets>
      <MiningSpeed>0.20</MiningSpeed>
      <ConstructionSpeed>0.20</ConstructionSpeed>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Mining</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Construction</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <ArmorRating_Sharp>0.25</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.25</ArmorRating_Blunt>
      <MoveSpeed>-0.60</MoveSpeed>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Fox Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Fox</defName>
    <label>Mark of the Fox</label>
    <description>The trickster, duelist, knife in the smile. Excels at evasive melee, ambush, and social manipulation.</description>
    <layerType>Mark</layerType>
    <titleSuffix>Shadow</titleSuffix>
    <passiveStatOffsets>
      <TradePriceImprovement>0.10</TradePriceImprovement>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Social</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Artistic</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <MeleeDodgeChance>0.15</MeleeDodgeChance>
      <MeleeHitChance>0.10</MeleeHitChance>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Raven Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Raven</defName>
    <label>Mark of the Raven</label>
    <description>The observer, tool-warrior, hunter-scholar. Prioritizes intellectual pursuit, weak-point precision, and prepared positions.</description>
    <layerType>Mark</layerType>
    <titleSuffix>Scholar</titleSuffix>
    <passiveStatOffsets>
      <ResearchSpeed>0.15</ResearchSpeed>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Intellectual</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Crafting</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <ShootingAccuracyPawn>2.50</ShootingAccuracyPawn>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Tiger Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Tiger</defName>
    <label>Mark of the Tiger</label>
    <description>The champion, predator, prestige warrior. Relies on melee force, intimidation, first-strike pressure, and athletic attacks.</description>
    <layerType>Mark</layerType>
    <titleSuffix>Claw</titleSuffix>
    <passiveStatOffsets>
      <TameAnimalChance>0.15</TameAnimalChance>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Social</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Animals</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <MeleeDamageFactor>0.25</MeleeDamageFactor>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Wolf Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Wolf</defName>
    <label>Mark of the Wolf</label>
    <description>The pack-fighter, raider, protector-pursuer. Strong synergy with allies, shock-and-disengage tactics, and pursuit.</description>
    <layerType>Mark</layerType>
    <titleSuffix>Fang</titleSuffix>
    <passiveStatOffsets>
      <TrainAnimalChance>0.15</TrainAnimalChance>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Animals</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Social</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <MoveSpeed>0.40</MoveSpeed>
      <MeleeHitChance>0.05</MeleeHitChance>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Crane Mark -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Mark_Crane</defName>
    <label>Mark of the Crane</label>
    <description>The graceful archer, martial artist, counterfighter. Values bow form, medical artistry, and calm fallback.</description>
    <layerType>Mark</layerType>
    <titleSuffix>feather</titleSuffix>
    <passiveStatOffsets>
      <MedicalTendQuality>0.15</MedicalTendQuality>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Medicine</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Artistic</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <MeleeDodgeChance>0.10</MeleeDodgeChance>
      <ShootingAccuracyPawn>1.50</ShootingAccuracyPawn>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

</Defs>
