        <skill>Social</skill>
        <amount>2</amount>
      </li>
      <li>
        <skill>Artistic</skill>
        <amount>2</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li Key="MeleeDodgeChance">0.15</li>
      <li Key="MeleeHitChance">0.10</li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Raven Mark -->
