<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Dragon Divine Beast -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Beast_Dragon</defName>
    <label>Dragon Alignment</label>
    <description>Sovereign Breath: unleashing devastating elemental force. Strong area damage and crowd breaking.</description>
    <layerType>DivineBeast</layerType>
    <titleSuffix>Dragon</titleSuffix>
    <passiveStatOffsets>
      <SocialImpact>0.15</SocialImpact>
    </passiveStatOffsets>
    <combatStatOffsets>
      <MentalBreakThreshold>-0.05</MentalBreakThreshold>
    </combatStatOffsets>
    <grantedAbilities>
      <li>Ability_SovereignBreath</li>
    </grantedAbilities>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Fenghuang Divine Beast -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Beast_Fenghuang</defName>
    <label>Fenghuang Alignment</label>
    <description>Ashen Covenant: self-resurrection through rebirth or sacrificial party-wide restoration.</description>
    <layerType>DivineBeast</layerType>
    <titleSuffix>Phoenix</titleSuffix>
    <passiveStatOffsets>
      <MedicalTendSpeed>0.15</MedicalTendSpeed>
    </passiveStatOffsets>
    <combatStatOffsets>
      <MedicalTendQuality>0.15</MedicalTendQuality>
    </combatStatOffsets>
    <grantedAbilities>
      <li>Ability_SovereignImmolation</li>
    </grantedAbilities>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Kitsune Divine Beast -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Beast_Kitsune</defName>
    <label>Kitsune Alignment</label>
    <description>Nine-Tail Mirage: blink displacement leaving a decoy illusion that breaks aggro.</description>
    <layerType>DivineBeast</layerType>
    <titleSuffix>Mirage</titleSuffix>
    <passiveStatOffsets>
      <NegotiationAbility>0.15</NegotiationAbility>
    </passiveStatOffsets>
    <combatStatOffsets>
      <MeleeDodgeChance>0.20</MeleeDodgeChance>
    </combatStatOffsets>
    <grantedAbilities>
      <li>Ability_NineTailMirage</li>
    </grantedAbilities>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Komainu Divine Beast -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Beast_Komainu</defName>
    <label>Komainu Alignment</label>
    <description>Guardian Gate: project a physical and projectile-blocking threshold barrier.</description>
    <layerType>DivineBeast</layerType>
    <titleSuffix>Gate</titleSuffix>
    <passiveStatOffsets>
      <GeneralLaborSpeed>0.15</GeneralLaborSpeed>
    </passiveStatOffsets>
    <combatStatOffsets>
      <ArmorRating_Sharp>0.20</ArmorRating_Sharp>
    </combatStatOffsets>
    <grantedAbilities>
      <li>Ability_GuardianGate</li>
    </grantedAbilities>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Basilisk Divine Beast -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Beast_Basilisk</defName>
    <label>Basilisk Alignment</label>
    <description>Stone-Gaze Mandate: mass stun or temporary petrification in a line of sight.</description>
    <layerType>DivineBeast</layerType>
    <titleSuffix>Gaze</titleSuffix>
    <passiveStatOffsets>
      <ToxicResistance>0.20</ToxicResistance>
    </passiveStatOffsets>
    <combatStatOffsets>
      <ToxicEnvironmentResistance>0.20</ToxicEnvironmentResistance>
    </combatStatOffsets>
    <grantedAbilities>
      <li>Ability_StoneGaze</li>
    </grantedAbilities>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- White Hart / Lu Divine Beast -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Beast_Lu</defName>
    <label>White Hart Alignment</label>
    <description>Sanctuary Path: create a path that stabilizes, speeds up, and guards allies in distress.</description>
    <layerType>DivineBeast</layerType>
    <titleSuffix>Hart</titleSuffix>
    <passiveStatOffsets>
      <AnimalGatherSpeed>0.15</AnimalGatherSpeed>
    </passiveStatOffsets>
    <combatStatOffsets>
      <MoveSpeed>0.50</MoveSpeed>
    </combatStatOffsets>
    <grantedAbilities>
      <li>Ability_SanctuaryPath</li>
    </grantedAbilities>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Stub Ability Definitions for compilation compatibility -->
  <AbilityDef>
    <defName>Ability_SovereignBreath</defName>
    <label>Sovereign Breath</label>
    <description>Unleash a supernatural cone of destructive force.</description>
    <cooldownTicksRange>12000</cooldownTicksRange> <!-- 2 hours in-game -->
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>15</range>
      <warmupTime>1.0</warmupTime>
    </verbProperties>
  </AbilityDef>

  <AbilityDef>
    <defName>Ability_SovereignImmolation</defName>
    <label>Sovereign Immolation</label>
    <description>Sacrifice the physical body to heal and stabilize all nearby allies.</description>
    <cooldownTicksRange>36000</cooldownTicksRange> <!-- 6 hours in-game -->
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>10</range>
      <warmupTime>2.0</warmupTime>
    </verbProperties>
  </AbilityDef>

  <AbilityDef>
    <defName>Ability_NineTailMirage</defName>
    <label>Nine-Tail Mirage</label>
    <description>Blink to a nearby position, leaving an illusion that attracts aggro.</description>
    <cooldownTicksRange>2500</cooldownTicksRange>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>15</range>
      <warmupTime>0.2</warmupTime>
    </verbProperties>
  </AbilityDef>

  <AbilityDef>
    <defName>Ability_GuardianGate</defName>
    <label>Guardian Gate</label>
    <description>Create a temporary force barrier protecting a chokepoint.</description>
    <cooldownTicksRange>6000</cooldownTicksRange>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>8</range>
      <warmupTime>1.5</warmupTime>
    </verbProperties>
  </AbilityDef>

  <AbilityDef>
    <defName>Ability_StoneGaze</defName>
    <label>Stone-Gaze Mandate</label>
    <description>Petrify and stun targets in a direct line of sight.</description>
    <cooldownTicksRange>5000</cooldownTicksRange>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>12</range>
      <warmupTime>0.5</warmupTime>
    </verbProperties>
  </AbilityDef>

  <AbilityDef>
    <defName>Ability_SanctuaryPath</defName>
    <label>Sanctuary Path</label>
    <description>Create a path of protection that guides and stabilizes retreating allies.</description>
    <cooldownTicksRange>4000</cooldownTicksRange>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <range>10</range>
      <warmupTime>1.0</warmupTime>
    </verbProperties>
  </AbilityDef>

</Defs>
