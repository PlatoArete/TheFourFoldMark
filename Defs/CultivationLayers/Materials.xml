<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Wood Material -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Material_Wood</defName>
    <label>Wood Constitution</label>
    <description>Living, adaptive, unfinished. Can sprout and bloom, but is vulnerable to decay and neglect.</description>
    <layerType>Material</layerType>
    <titleSuffix>Sprout</titleSuffix>
    <passiveStatOffsets>
      <li>
        <stat>PlantWorkSpeed</stat>
        <value>0.25</value>
      </li>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Plants</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li>
        <stat>MoveSpeed</stat>
        <value>0.50</value>
      </li>
      <li>
        <stat>MeleeDodgeChance</stat>
        <value>0.10</value>
      </li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Steel Material -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Material_Steel</defName>
    <label>Steel Constitution</label>
    <description>Forged, committed, defined. Offers locked-in, robust bonuses and predictable, stable performance.</description>
    <layerType>Material</layerType>
    <titleSuffix>Iron</titleSuffix>
    <passiveStatOffsets>
      <li>
        <stat>WorkSpeedGlobal</stat>
        <value>0.15</value>
      </li>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Crafting</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li>
        <stat>ArmorRating_Sharp</stat>
        <value>0.15</value>
      </li>
      <li>
        <stat>ArmorRating_Blunt</stat>
        <value>0.15</value>
      </li>
      <li>
        <stat>PainShockThreshold</stat>
        <value>0.10</value>
      </li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Jade Material -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Material_Jade</defName>
    <label>Jade Constitution</label>
    <description>Slow-formed, perfected, revealed. Highest permanence and psychic resilience, but takes longest to mature.</description>
    <layerType>Material</layerType>
    <titleSuffix>Jade</titleSuffix>
    <passiveStatOffsets>
      <li>
        <stat>PsychicSensitivity</stat>
        <value>0.30</value>
      </li>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Artistic</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <li>
        <stat>PainShockThreshold</stat>
        <value>0.30</value>
      </li>
      <li>
        <stat>MentalBreakThreshold</stat>
        <value>-0.08</value>
      </li>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

</Defs>
