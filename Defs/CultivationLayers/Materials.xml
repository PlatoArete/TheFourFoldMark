<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Wood Material -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Material_Wood</defName>
    <label>Wood Constitution</label>
    <description>Living, adaptive, unfinished. Can sprout and bloom, but is vulnerable to decay and neglect.</description>
    <layerType>Material</layerType>
    <titleSuffix>Sprout</titleSuffix>
    <passiveStatOffsets>
      <PlantWorkSpeed>0.25</PlantWorkSpeed>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Plants</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <MoveSpeed>0.50</MoveSpeed>
      <MeleeDodgeChance>0.10</MeleeDodgeChance>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Steel Material -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Material_Steel</defName>
    <label>Steel Constitution</label>
    <description>Forged, committed, defined. Offers locked-in, robust bonuses and predictable, stable performance.</description>
    <layerType>Material</layerType>
    <titleSuffix>Iron</titleSuffix>
    <passiveStatOffsets>
      <WorkSpeedGlobal>0.15</WorkSpeedGlobal>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Crafting</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <ArmorRating_Sharp>0.15</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.15</ArmorRating_Blunt>
      <PainShockThreshold>0.10</PainShockThreshold>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

  <!-- Jade Material -->
  <RimWorldCultivation.CultivationLayerDef>
    <defName>Material_Jade</defName>
    <label>Jade Constitution</label>
    <description>Slow-formed, perfected, revealed. Highest permanence and psychic resilience, but takes longest to mature.</description>
    <layerType>Material</layerType>
    <titleSuffix>Jade</titleSuffix>
    <passiveStatOffsets>
      <PsychicSensitivity>0.30</PsychicSensitivity>
    </passiveStatOffsets>
    <civilianSkillPulls>
      <li>
        <skill>Artistic</skill>
        <amount>3</amount>
      </li>
    </civilianSkillPulls>
    <combatStatOffsets>
      <PainShockThreshold>0.30</PainShockThreshold>
      <MentalBreakThreshold>-0.08</MentalBreakThreshold>
    </combatStatOffsets>
  </RimWorldCultivation.CultivationLayerDef>

</Defs>
